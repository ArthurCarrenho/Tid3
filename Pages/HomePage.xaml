<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TidalUi3.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:TidalUi3.Models"
    xmlns:controls="using:TidalUi3.Controls"
    mc:Ignorable="d"
>

    <Grid>
        <controls:LoadingOverlayControl x:Name="HomeLoading" />
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
            <StackPanel Spacing="32" Padding="36,24,36,120">

                <!-- Header -->
                <TextBlock
                    x:Uid="HomeHeader"
                    Style="{StaticResource TitleLargeTextBlockStyle}"
                    Margin="0,0,0,-16"
                />

                <!-- Dynamic Sections -->
                <ItemsControl x:Name="SectionsHost">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:HomeSection">
                            <StackPanel Spacing="16" Margin="0,0,0,16">
                                <!-- Section Title -->
                                <TextBlock
                                    Text="{x:Bind Title}"
                                    Style="{StaticResource SubtitleTextBlockStyle}"
                                    VerticalAlignment="Center"
                                />

                                <!-- Horizontal scrolling cards -->
                                <ScrollViewer
                                    HorizontalScrollBarVisibility="Auto"
                                    VerticalScrollBarVisibility="Disabled"
                                    HorizontalScrollMode="Enabled"
                                    VerticalScrollMode="Disabled"
                                >
                                    <GridView
                                        x:Name="ItemsGrid"
                                        ItemsSource="{x:Bind Items}"
                                        SelectionMode="None"
                                        IsItemClickEnabled="True"
                                        ItemClick="SectionItem_Click"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                    >
                                        <GridView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsStackPanel
                                                    Orientation="Horizontal"
                                                />
                                            </ItemsPanelTemplate>
                                        </GridView.ItemsPanel>
                                        <GridView.ItemTemplate>
                                            <DataTemplate>
                                                <controls:MediaCardControl
                                                    CardWidth="180"
                                                    TitleText="{Binding Title}"
                                                    SubtitleText="{Binding Subtitle}"
                                                    ImageUrl="{Binding CoverUrl}"
                                                    FallbackGlyph="&#xE8D6;"
                                                />
                                            </DataTemplate>
                                        </GridView.ItemTemplate>
                                    </GridView>
                                </ScrollViewer>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</Page>
