<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TidalUi3.Pages.DebugPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════ -->
        <!--  ROW 0 — Controls                                     -->
        <!-- ══════════════════════════════════════════════════════ -->
        <StackPanel Padding="36,24,36,0" Spacing="8">

            <TextBlock
                Text="Debug"
                Style="{StaticResource TitleLargeTextBlockStyle}"
                Margin="0,0,0,12"
            />

            <!-- ── Authentication ── -->
            <TextBlock Text="Authentication" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,4" />

            <Grid
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,14"
            >
                <StackPanel Spacing="10">
                    <TextBlock
                        Text="Access Token"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    />
                    <TextBox
                        x:Name="TokenBox"
                        IsReadOnly="True"
                        TextWrapping="Wrap"
                        MaxHeight="80"
                        FontSize="11"
                        FontFamily="Consolas"
                        AcceptsReturn="True"
                    />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="CopyTokenButton" Click="CopyTokenButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="13" />
                                <TextBlock Text="Copy" />
                            </StackPanel>
                        </Button>
                        <TextBlock
                            x:Name="UserInfoText"
                            VerticalAlignment="Center"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ── Request Tester ── -->
            <TextBlock Text="Request Tester" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,4" />

            <!-- Controls bar -->
            <Grid ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="82" />
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox
                    x:Name="MethodCombo"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="MethodCombo_SelectionChanged"
                    SelectedIndex="0"
                    FontFamily="Consolas"
                >
                    <ComboBoxItem Content="GET" />
                    <ComboBoxItem Content="POST" />
                    <ComboBoxItem Content="DELETE" />
                </ComboBox>

                <ComboBox
                    x:Name="EndpointCombo"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="EndpointCombo_SelectionChanged"
                    PlaceholderText="Endpoint…"
                />

                <TextBox
                    x:Name="UrlBox"
                    Grid.Column="2"
                    FontFamily="Consolas"
                    FontSize="12"
                    PlaceholderText="https://api.tidalhifi.com/v1/…"
                    KeyDown="UrlBox_KeyDown"
                />

                <Button
                    x:Name="SendButton"
                    Grid.Column="3"
                    Click="SendButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                >
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE768;" FontSize="13" />
                        <TextBlock Text="Send" />
                    </StackPanel>
                </Button>

                <!-- Save endpoint button with inline flyout -->
                <Button
                    x:Name="SaveButton"
                    Grid.Column="4"
                    ToolTipService.ToolTip="Save endpoint"
                >
                    <FontIcon Glyph="&#xE74E;" FontSize="13" />
                    <Button.Flyout>
                        <Flyout x:Name="SaveFlyout" Placement="Bottom">
                            <StackPanel Width="280" Spacing="12" Padding="4">
                                <TextBox
                                    x:Name="SaveNameBox"
                                    Header="Name"
                                    PlaceholderText="e.g. Artist top tracks"
                                />
                                <TextBox
                                    x:Name="SaveNotesBox"
                                    Header="Notes"
                                    PlaceholderText="What does this endpoint return?"
                                    AcceptsReturn="True"
                                    Height="60"
                                />
                                <Button
                                    Content="Save"
                                    Click="ConfirmSave_Click"
                                    Style="{StaticResource AccentButtonStyle}"
                                    HorizontalAlignment="Right"
                                />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!-- Compare toggle -->
                <ToggleButton
                    x:Name="CompareToggle"
                    Grid.Column="5"
                    Click="CompareToggle_Click"
                    ToolTipService.ToolTip="Side-by-side compare mode"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Padding="10,6"
                >A|B</ToggleButton>

                <Button
                    x:Name="ClearButton"
                    Grid.Column="6"
                    Click="ClearButton_Click"
                    ToolTipService.ToolTip="Clear"
                >
                    <FontIcon Glyph="&#xE74D;" FontSize="13" />
                </Button>
            </Grid>

            <!-- Headers expander -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="Custom headers" Style="{StaticResource CaptionTextBlockStyle}" />
                </Expander.Header>
                <TextBox
                    x:Name="HeadersBox"
                    PlaceholderText="Key: Value&#x0a;Another-Header: Value2"
                    AcceptsReturn="True"
                    Height="76"
                    FontFamily="Consolas"
                    FontSize="12"
                    TextWrapping="Wrap"
                    Margin="0,4"
                />
            </Expander>

            <!-- Body expander (hidden for GET) -->
            <Expander
                x:Name="BodyExpander"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Visibility="Collapsed"
            >
                <Expander.Header>
                    <TextBlock Text="Request body" Style="{StaticResource CaptionTextBlockStyle}" />
                </Expander.Header>
                <StackPanel Spacing="8" Margin="0,4">
                    <ComboBox x:Name="ContentTypeCombo" Header="Content-Type" SelectedIndex="0">
                        <ComboBoxItem Content="application/x-www-form-urlencoded" />
                        <ComboBoxItem Content="application/json" />
                        <ComboBoxItem Content="text/plain" />
                    </ComboBox>
                    <TextBox
                        x:Name="BodyBox"
                        PlaceholderText="trackId=59978879&amp;countryCode=US"
                        AcceptsReturn="True"
                        Height="76"
                        FontFamily="Consolas"
                        FontSize="12"
                        TextWrapping="Wrap"
                    />
                </StackPanel>
            </Expander>

            <!-- Status bar -->
            <StackPanel Orientation="Horizontal" Spacing="10" Height="20">
                <ProgressRing x:Name="RequestProgress" IsActive="False" Width="16" Height="16" />
                <TextBlock
                    x:Name="StatusText"
                    VerticalAlignment="Center"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                />
            </StackPanel>

            <!-- Response view toolbar (hidden in compare mode) -->
            <StackPanel
                x:Name="ResponseToolbar"
                Orientation="Horizontal"
                Spacing="6"
            >
                <ToggleButton
                    x:Name="RawModeButton"
                    Content="Raw"
                    IsChecked="True"
                    Click="RawModeButton_Click"
                    Padding="10,5"
                />
                <ToggleButton
                    x:Name="TreeModeButton"
                    Content="Tree"
                    IsChecked="False"
                    Click="TreeModeButton_Click"
                    Padding="10,5"
                />
                <TextBox
                    x:Name="TreeSearchBox"
                    PlaceholderText="Search keys / values…"
                    Width="200"
                    Visibility="Collapsed"
                    TextChanged="TreeSearchBox_TextChanged"
                />
                <TextBlock
                    x:Name="CopiedPathText"
                    VerticalAlignment="Center"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Visibility="Collapsed"
                />
            </StackPanel>

        </StackPanel>
        <!-- /ROW 0 -->

        <!-- ══════════════════════════════════════════════════════ -->
        <!--  ROW 1 — Response area + History panel                -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="36,6,36,24" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="HistoryColumnDef" Width="260" />
            </Grid.ColumnDefinitions>

            <!-- ── Response area (normal + tree + compare, overlaid) ── -->
            <Grid>

                <!-- Raw TextBox -->
                <TextBox
                    x:Name="ResponseText"
                    IsReadOnly="True"
                    AcceptsReturn="True"
                    TextWrapping="NoWrap"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    FontFamily="Consolas"
                    FontSize="12"
                    CornerRadius="8"
                />

                <!-- Tree mode -->
                <Grid x:Name="TreeArea" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Flat search results (shown when search active) -->
                    <ListView
                        x:Name="TreeSearchResultsList"
                        Grid.Row="0"
                        MaxHeight="180"
                        Visibility="Collapsed"
                        SelectionMode="Single"
                        SelectionChanged="TreeSearchResult_SelectionChanged"
                    >
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding}"
                                    FontFamily="Consolas"
                                    FontSize="11"
                                    TextTrimming="CharacterEllipsis"
                                />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Tree view -->
                    <TreeView
                        x:Name="ResponseTree"
                        Grid.Row="1"
                        ItemInvoked="ResponseTree_ItemInvoked"
                    >
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding Content.Label}"
                                    FontFamily="Consolas"
                                    FontSize="11.5"
                                    TextTrimming="CharacterEllipsis"
                                />
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>

                <!-- Compare mode -->
                <Grid x:Name="CompareGrid" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="DiffOutputRow" Height="0" />
                    </Grid.RowDefinitions>

                    <!-- URL inputs (A and B) -->
                    <Grid ColumnSpacing="8" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Side A -->
                        <StackPanel Spacing="4">
                            <TextBlock
                                Text="A"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                FontWeight="SemiBold"
                            />
                            <Grid ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="UrlBoxA"
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    PlaceholderText="URL A…"
                                />
                                <Button
                                    Grid.Column="1"
                                    Click="SendA_Click"
                                    Style="{StaticResource AccentButtonStyle}"
                                >
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <ProgressRing x:Name="ProgressA" IsActive="False" Width="12" Height="12" />
                                        <TextBlock Text="Send" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Grid.Column="2"
                                    Click="UseCurrentA_Click"
                                    ToolTipService.ToolTip="Copy current URL here"
                                >
                                    <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                                </Button>
                            </Grid>
                            <TextBlock
                                x:Name="StatusTextA"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            />
                        </StackPanel>

                        <!-- Side B -->
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock
                                Text="B"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                FontWeight="SemiBold"
                            />
                            <Grid ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="UrlBoxB"
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    PlaceholderText="URL B…"
                                />
                                <Button
                                    Grid.Column="1"
                                    Click="SendB_Click"
                                    Style="{StaticResource AccentButtonStyle}"
                                >
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <ProgressRing x:Name="ProgressB" IsActive="False" Width="12" Height="12" />
                                        <TextBlock Text="Send" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Grid.Column="2"
                                    Click="UseCurrentB_Click"
                                    ToolTipService.ToolTip="Copy current URL here"
                                >
                                    <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                                </Button>
                            </Grid>
                            <TextBlock
                                x:Name="StatusTextB"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            />
                        </StackPanel>
                    </Grid>

                    <!-- Response TextBoxes (A and B) -->
                    <Grid Grid.Row="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="ResponseTextA"
                            IsReadOnly="True"
                            AcceptsReturn="True"
                            TextWrapping="NoWrap"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            FontFamily="Consolas"
                            FontSize="12"
                            CornerRadius="8"
                        />
                        <TextBox
                            x:Name="ResponseTextB"
                            Grid.Column="1"
                            IsReadOnly="True"
                            AcceptsReturn="True"
                            TextWrapping="NoWrap"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            FontFamily="Consolas"
                            FontSize="12"
                            CornerRadius="8"
                        />
                    </Grid>

                    <!-- Diff toolbar -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,6">
                        <Button Click="RunDiff_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8A9;" FontSize="13" />
                                <TextBlock Text="Diff A vs B" />
                            </StackPanel>
                        </Button>
                        <Button Click="SwapAB_Click" ToolTipService.ToolTip="Swap A and B">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8AB;" FontSize="13" />
                                <TextBlock Text="Swap" />
                            </StackPanel>
                        </Button>
                        <TextBlock
                            x:Name="DiffStatusText"
                            VerticalAlignment="Center"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        />
                    </StackPanel>

                    <!-- Diff output -->
                    <TextBox
                        x:Name="DiffText"
                        Grid.Row="3"
                        IsReadOnly="True"
                        AcceptsReturn="True"
                        TextWrapping="NoWrap"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        FontFamily="Consolas"
                        FontSize="11.5"
                        CornerRadius="8"
                    />
                </Grid>

            </Grid>
            <!-- /Response area -->

            <!-- ── History panel ── -->
            <Grid x:Name="HistoryPanel" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Text="History"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        VerticalAlignment="Center"
                    />
                    <Button
                        Grid.Column="1"
                        Click="ClearHistory_Click"
                        Padding="6,4"
                        ToolTipService.ToolTip="Clear history"
                    >
                        <FontIcon Glyph="&#xE74D;" FontSize="12" />
                    </Button>
                </Grid>

                <!-- List -->
                <ListView
                    x:Name="HistoryList"
                    Grid.Row="1"
                    SelectionMode="Single"
                    SelectionChanged="HistoryList_SelectionChanged"
                >
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="8,5" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <Border CornerRadius="3" Padding="4,1" Background="{Binding StatusBrush}">
                                        <TextBlock
                                            Text="{Binding StatusText}"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                        />
                                    </Border>
                                    <TextBlock
                                        Text="{Binding Method}"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        FontFamily="Consolas"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"
                                    />
                                    <TextBlock
                                        Text="{Binding ElapsedText}"
                                        FontSize="10"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        VerticalAlignment="Center"
                                    />
                                </StackPanel>
                                <TextBlock
                                    Text="{Binding DisplayUrl}"
                                    FontFamily="Consolas"
                                    FontSize="10.5"
                                    TextTrimming="CharacterEllipsis"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Footer -->
                <Button
                    Grid.Row="2"
                    Click="ExportSaved_Click"
                    HorizontalAlignment="Stretch"
                    Margin="0,6,0,0"
                >
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A7;" FontSize="13" />
                        <TextBlock Text="Export saved endpoints" />
                    </StackPanel>
                </Button>

            </Grid>
            <!-- /History panel -->

        </Grid>
        <!-- /ROW 1 -->

    </Grid>
</Page>
