<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TidalUi3.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
>

    <Grid>
        <!-- Centered card -->
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="32"
            MaxWidth="420"
            Padding="40"
        >

            <!-- Logo area -->
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <Image
                    Source="ms-appx:///Assets/Square150x150Logo.scale-200.png"
                    Width="72"
                    Height="72"
                    HorizontalAlignment="Center"
                />
                <TextBlock
                    Text="T I D 3"
                    FontSize="28"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                />
            </StackPanel>

            <!-- Instruction -->
            <StackPanel Spacing="6" HorizontalAlignment="Center">
                <TextBlock
                    x:Uid="LoginInstruction_Title"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    HorizontalAlignment="Center"
                />
                <TextBlock
                    x:Uid="LoginInstruction_Body"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                />
            </StackPanel>

            <!-- Code display -->
            <Grid
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="24,20"
                HorizontalAlignment="Center"
                MinWidth="300"
            >
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock
                        x:Uid="LoginCode_YourCode"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center"
                    />
                    <TextBlock
                        x:Name="DeviceCodeText"
                        Text="ABCD-1234"
                        FontSize="32"
                        FontWeight="Bold"
                        FontFamily="Consolas"
                        HorizontalAlignment="Center"
                        IsTextSelectionEnabled="True"
                        CharacterSpacing="150"
                    />
                    <Button
                        x:Name="CopyCodeButton"
                        HorizontalAlignment="Center"
                        Click="CopyCodeButton_Click"
                        Padding="12,6"
                    >
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8C8;" FontSize="13" />
                            <TextBlock
                                x:Name="CopyButtonText"
                                x:Uid="LoginCode_CopyButton"
                                FontSize="12"
                            />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Link -->
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock
                    x:Uid="LoginVisit_Title"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                />
                <HyperlinkButton
                    x:Name="LinkButton"
                    Content="link.tidal.com/authorize"
                    HorizontalAlignment="Center"
                    FontSize="15"
                    Click="LinkButton_Click"
                />
            </StackPanel>

            <!-- Status / spinner -->
            <StackPanel
                x:Name="WaitingPanel"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="10"
            >
                <ProgressRing
                    x:Name="WaitingSpinner"
                    IsActive="True"
                    Width="20"
                    Height="20"
                />
                <TextBlock
                    x:Name="StatusText"
                    x:Uid="LoginStatus_Waiting"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Center"
                />
            </StackPanel>

            <!-- Action buttons -->
            <StackPanel Spacing="10" HorizontalAlignment="Center">
                <Button
                    x:Name="RefreshCodeButton"
                    HorizontalAlignment="Center"
                    Style="{StaticResource SubtleButtonStyle}"
                    Padding="16,8"
                    Click="RefreshCodeButton_Click"
                >
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon
                            Glyph="&#xE72C;"
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        />
                        <TextBlock
                            x:Uid="LoginRefresh_Button"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Expiry hint -->
            <TextBlock
                x:Name="ExpiryText"
                Text="Code expires in 4:59"
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                HorizontalAlignment="Center"
            />
        </StackPanel>
    </Grid>
</Page>
