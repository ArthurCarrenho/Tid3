<?xml version="1.0" encoding="utf-8"?>

<UserControl
    x:Class="TidalUi3.Controls.VolumeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Orientation="Horizontal" Spacing="4">
        <Button x:Name="MuteButton" Width="28" Height="28" Padding="0"
                Background="Transparent" BorderThickness="0" CornerRadius="14"
                Click="MuteButton_Click">
            <FontIcon x:Name="VolumeIcon" Glyph="&#xE767;" FontSize="14"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Button>
        <Slider x:Name="VolumeSlider" Value="75" Maximum="100"
                Width="90" VerticalAlignment="Center"
                ValueChanged="VolumeSlider_ValueChanged" />
    </StackPanel>
</UserControl>
