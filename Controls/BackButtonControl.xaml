<?xml version="1.0" encoding="utf-8"?>

<UserControl
    x:Class="TidalUi3.Controls.BackButtonControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Icon-only style (default) -->
    <Button x:Name="InnerButton" Click="InnerButton_Click"
            Style="{StaticResource SubtleButtonStyle}"
            Width="36" Height="36" Padding="0" HorizontalAlignment="Left">
        <StackPanel x:Name="ContentPanel" Orientation="Horizontal" Spacing="8">
            <FontIcon Glyph="&#xE72B;" FontSize="14" />
            <TextBlock x:Name="LabelText" Text="Back" Visibility="Collapsed" />
        </StackPanel>
    </Button>
</UserControl>
