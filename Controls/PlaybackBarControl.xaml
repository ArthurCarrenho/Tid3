<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="TidalUi3.Controls.PlaybackBarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TidalUi3.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="UserControl_Loaded"
    Unloaded="UserControl_Unloaded"
    mc:Ignorable="d"
>

    <Grid
        Height="100"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="0,1,0,0"
        Padding="16,0"
    >

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Now Playing Info (left) -->
        <StackPanel
            x:Name="NowPlayingPanel"
            Orientation="Horizontal"
            VerticalAlignment="Center"
            Spacing="12"
            Visibility="Collapsed"
        >
            <StackPanel.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem x:Uid="PlaybackBar_Context_GoToArtist" Click="Context_GoToArtist_Click" />
                    <MenuFlyoutItem x:Uid="PlaybackBar_Context_GoToAlbum" Click="Context_GoToAlbum_Click" />
                </MenuFlyout>
            </StackPanel.ContextFlyout>
            
            <Grid
                x:Name="NowPlayingArt"
                Width="48"
                Height="48"
                CornerRadius="4"
                Background="#2D2D2D"
            >
                <FontIcon
                    Glyph="&#xE8D6;"
                    FontSize="20"
                    Foreground="#55FFFFFF"
                />
                <Image x:Name="NowPlayingCover" Stretch="UniformToFill" />
            </Grid>
            <StackPanel VerticalAlignment="Center" Spacing="1" MaxWidth="130">
                <TextBlock
                    x:Name="NowPlayingTitle"
                    Text=""
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    TextTrimming="CharacterEllipsis"
                />
                <TextBlock
                    x:Name="NowPlayingArtist"
                    Text=""
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextTrimming="CharacterEllipsis"
                />
            </StackPanel>
            <Button
                x:Name="LikeButton"
                Style="{StaticResource SubtleButtonStyle}"
                VerticalAlignment="Center"
                Width="32"
                Height="32"
                Padding="0"
                Click="LikeButton_Click"
                x:Uid="PlaybackBar_Like"
            >
                <FontIcon
                    x:Name="LikeIcon"
                    Glyph="&#xEB51;"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                />
            </Button>
        </StackPanel>

        <!-- Transport + Progress (center) -->
        <Grid Grid.Column="1" VerticalAlignment="Center" MaxWidth="620">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Transport buttons -->
            <local:TransportControls
                x:Name="TransportControls"
                Margin="0,0,0,-10"
                PlayPauseClick="TransportControls_PlayPauseClick"
                PreviousClick="TransportControls_PreviousClick"
                NextClick="TransportControls_NextClick"
                ShuffleClick="TransportControls_ShuffleClick"
                RepeatClick="TransportControls_RepeatClick"
            />

            <!-- Progress row -->
            <Grid Grid.Row="1" Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="38" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="38" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="CurrentTimeText"
                    Text="0:00"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                />
                <Slider
                    x:Name="ProgressSlider"
                    Grid.Column="1"
                    Value="0"
                    Maximum="100"
                    VerticalAlignment="Center"
                    Margin="8,0"
                    PointerPressed="ProgressSlider_PointerPressed"
                    PointerReleased="ProgressSlider_PointerReleased"
                    PointerCaptureLost="ProgressSlider_PointerReleased"
                />
                <TextBlock
                    x:Name="TotalTimeText"
                    Text="0:00"
                    Grid.Column="2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                />
            </Grid>
        </Grid>

        <!-- Volume & Extras (right) -->
        <StackPanel
            Grid.Column="2"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Spacing="2"
        >
            <!-- Devices / Connect -->
            <Button
                x:Name="DevicesButton"
                Width="38"
                Height="38"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                CornerRadius="19"
                x:Uid="PlaybackBar_Devices"
                Visibility="Collapsed"
            >
                <Grid>
                    <FontIcon
                        Glyph="&#xE975;"
                        FontSize="16"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    />
                    <!-- Status Dot -->
                    <Ellipse
                        x:Name="SyncStatusDot"
                        Width="8"
                        Height="8"
                        Fill="#FF4444" 
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,2,2,0"
                        Stroke="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        StrokeThickness="1.5"
                    />
                </Grid>
                <Button.Flyout>
                    <Flyout x:Name="DevicesFlyout">
                        <StackPanel Width="280" Spacing="8">
                            <TextBlock x:Uid="PlaybackBar_Devices_Header" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="4,4,4,0"/>

                            <!-- This Device -->
                            <Grid
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="6"
                                Padding="12,10"
                            >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Glyph="&#xE770;"
                                    FontSize="18"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0"
                                    Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                    <TextBlock x:Name="ThisDeviceName" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock
                                        x:Name="ThisDeviceStatus"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                    />
                                </StackPanel>
                                <FontIcon
                                    Grid.Column="2"
                                    Glyph="&#xE8FB;"
                                    FontSize="14"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                />
                            </Grid>

                            <!-- Other Devices -->
                            <TextBlock
                                x:Uid="PlaybackBar_Devices_OtherDevices"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Margin="4,0,4,0"
                            />

                            <TextBlock
                                x:Name="NoDevicesText"
                                x:Uid="PlaybackBar_Devices_None"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Margin="4,0,4,0"
                                Visibility="Collapsed"
                            />

                            <ListView x:Name="DevicesListView" SelectionMode="None" BorderThickness="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Button
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="8,10"
                                            Click="DeviceItem_Click"
                                        >
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Glyph="&#xE770;" FontSize="18" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                    <TextBlock x:Uid="PlaybackBar_Devices_Transfer" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- Settings Link -->
                            <Button
                                x:Uid="PlaybackBar_Devices_SyncSettings"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Click="SyncSettingsButton_Click"
                                Margin="0,4,0,0"
                            />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <Button
                x:Name="LyricsToggleButton"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                CornerRadius="16"
                Click="LyricsButton_Click"
                x:Uid="PlaybackBar_Lyrics"
            >
                <FontIcon
                    x:Name="LyricsIcon"
                    Glyph="&#xED1E;"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                />
            </Button>
            <Button
                x:Name="QueueButton"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                CornerRadius="16"
                Click="QueueButton_Click"
                x:Uid="PlaybackBar_Queue"
            >
                <FontIcon
                    x:Name="QueueIcon"
                    Glyph="&#xE90B;"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                />
            </Button>
            <Button
                x:Name="QualityButton"
                Click="QualityButton_Click"
                BorderThickness="0"
                Padding="4,4"
                Margin="2,0"
                Background="#00000000"
                Visibility="Collapsed"
            >
                <TextBlock
                    x:Name="QualityText"
                    Text=""
                    FontSize="11"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Foreground="#00000000"
                />
            </Button>
            <local:VolumeControl
                x:Name="VolumeControl"
                Margin="6,0,0,0"
                VolumeChanged="VolumeControl_VolumeChanged"
            />
        </StackPanel>
    </Grid>
</UserControl>
